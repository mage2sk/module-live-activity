<script>
function productPicker_<?= $block->escapeJs($elementId) ?>() {
    return {
        productIds: '<?= $block->escapeJs($elementValue) ?>',
        selectedProducts: [],
        tempSelected: [],
        searchTerm: '',
        searchedProducts: [],
        totalResults: 0,
        page: 1,
        hasMore: false,
        loading: false,
        showModal: false,

        init() {
            if (this.productIds) {
                this.loadExistingProducts();
            }
        },

        loadExistingProducts() {
            fetch('<?= $block->escapeJs($block->getGetByIdsUrl()) ?>', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: new URLSearchParams({
                    'form_key': '<?= $block->escapeJs($block->getFormKey()) ?>',
                    'ids': this.productIds
                })
            })
            .then(r => r.json())
            .then(data => {
                if (data.success && data.products) {
                    this.selectedProducts = data.products;
                }
            });
        },

        openModal() {
            this.showModal = true;
            this.tempSelected = [...this.selectedProducts];
            this.searchTerm = '';
            this.searchedProducts = [];
        },

        closeModal() {
            this.showModal = false;
            this.searchTerm = '';
            this.searchedProducts = [];
        },

        confirmSelection() {
            this.selectedProducts = [...this.tempSelected];
            this.productIds = this.selectedProducts.map(p => p.id).join(',');
            this.closeModal();
        },

        searchProducts() {
            if (this.searchTerm.length < 2) {
                this.searchedProducts = [];
                return;
            }

            this.page = 1;
            this.loading = true;

            fetch('<?= $block->escapeJs($block->getSearchUrl()) ?>', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: new URLSearchParams({
                    'form_key': '<?= $block->escapeJs($block->getFormKey()) ?>',
                    'query': this.searchTerm,
                    'page': this.page,
                    'limit': 10
                })
            })
            .then(r => r.json())
            .then(data => {
                this.loading = false;
                if (data.success) {
                    this.searchedProducts = data.products;
                    this.totalResults = data.total;
                    this.hasMore = data.has_more;
                }
            })
            .catch(() => this.loading = false);
        },

        loadMore() {
            this.page++;
            this.loading = true;

            fetch('<?= $block->escapeJs($block->getSearchUrl()) ?>', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: new URLSearchParams({
                    'form_key': '<?= $block->escapeJs($block->getFormKey()) ?>',
                    'query': this.searchTerm,
                    'page': this.page,
                    'limit': 10
                })
            })
            .then(r => r.json())
            .then(data => {
                this.loading = false;
                if (data.success) {
                    this.searchedProducts = [...this.searchedProducts, ...data.products];
                    this.hasMore = data.has_more;
                }
            })
            .catch(() => this.loading = false);
        },

        toggleProduct(product) {
            const index = this.tempSelected.findIndex(p => p.id === product.id);
            if (index >= 0) {
                this.tempSelected.splice(index, 1);
            } else {
                this.tempSelected.push(product);
            }
        },

        isSelected(productId) {
            return this.tempSelected.some(p => p.id === productId);
        },

        removeProduct(productId) {
            this.selectedProducts = this.selectedProducts.filter(p => p.id !== productId);
            this.productIds = this.selectedProducts.map(p => p.id).join(',');
        }
    }
}
</script>

