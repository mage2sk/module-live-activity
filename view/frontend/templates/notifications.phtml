<script>
(function() {
    'use strict';

    var LiveActivityNotifications = function() {
        this.config = {};
        this.ajaxUrl = '';
        this.productId = null;
        this.activities = [];
        this.visibleNotifications = [];
        this.currentIndex = 0;
        this.notificationCount = 0;
        this.isShowingNotification = false;
        this.touchStartTime = 0;
        this.touchStartX = 0;
        this.touchStartY = 0;
        this.container = null;
    };

    LiveActivityNotifications.prototype.init = function() {
        this.container = document.getElementById('live-activity-container');
        if (!this.container) {
            return;
        }

        this.config = JSON.parse(this.container.dataset.config || '{}');
        this.ajaxUrl = this.container.dataset.ajaxUrl;
        this.productId = this.container.dataset.productId || null;

        if (!this.config.enabled) {
            return;
        }

        var isMobile = this.isMobileDevice();
        if (!this.config.mobileEnabled && isMobile) {
            return;
        }

        this.fetchActivities();
    };

    LiveActivityNotifications.prototype.isMobileDevice = function() {
        var isMobileWidth = window.innerWidth < 768;
        var hasTouch = 'ontouchstart' in window ||
                       navigator.maxTouchPoints > 0 ||
                       navigator.msMaxTouchPoints > 0;
        var mobileUserAgent = /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent);

        return isMobileWidth || (hasTouch && mobileUserAgent);
    };

    LiveActivityNotifications.prototype.fetchActivities = function() {
        var self = this;
        var url = this.productId
            ? this.ajaxUrl + '?product_id=' + this.productId
            : this.ajaxUrl;

        fetch(url)
            .then(function(response) { return response.json(); })
            .then(function(data) {
                if (data.success && data.activities) {
                    self.activities = data.activities;
                    self.startNotifications();
                }
            })
            .catch(function(error) {
                // Silent fail
            });
    };

    LiveActivityNotifications.prototype.startNotifications = function() {
        var self = this;
        if (this.activities.length === 0) {
            return;
        }

        setTimeout(function() {
            self.showNextNotification();
        }, this.config.displayDelay);
    };

    LiveActivityNotifications.prototype.showNextNotification = function() {
        var self = this;

        if (this.isShowingNotification) {
            return;
        }

        if (this.activities.length === 0) {
            return;
        }

        if (this.config.maxNotifications > 0 && this.notificationCount >= this.config.maxNotifications) {
            return;
        }

        this.isShowingNotification = true;
        this.clearVisibleNotifications();

        var activity = this.activities[this.currentIndex % this.activities.length];
        this.currentIndex++;
        this.notificationCount++;

        var notification = {
            id: Date.now() + Math.random(),
            element: null
        };

        for (var key in activity) {
            if (activity.hasOwnProperty(key)) {
                notification[key] = activity[key];
            }
        }

        notification.visible = true;

        this.visibleNotifications = [notification];
        this.renderNotification(notification);

        setTimeout(function() {
            self.closeNotification(notification.id);

            setTimeout(function() {
                self.isShowingNotification = false;

                setTimeout(function() {
                    self.showNextNotification();
                }, self.config.interval);
            }, 300);
        }, this.config.duration);
    };

    LiveActivityNotifications.prototype.clearVisibleNotifications = function() {
        for (var i = 0; i < this.visibleNotifications.length; i++) {
            var notif = this.visibleNotifications[i];
            if (notif.element && notif.element.parentNode) {
                notif.element.parentNode.removeChild(notif.element);
            }
        }
        this.visibleNotifications = [];
    };

    LiveActivityNotifications.prototype.renderNotification = function(notification) {
        var self = this;
        var notifDiv = document.createElement('div');

        var positionClass = 'live-activity-' + this.config.position;
        var animationClass = 'live-activity-animation-' + this.config.animation;
        var clickableClass = notification.product_url ? ' live-activity-clickable' : '';

        notifDiv.className = 'live-activity-notification ' + positionClass + ' ' + animationClass + clickableClass + ' notification-enter-start';
        notifDiv.dataset.notificationId = notification.id;

        if (this.config.showIcon) {
            notifDiv.appendChild(this.createIcon(notification.type));
        }

        if (this.config.showImage && notification.product_image) {
            notifDiv.appendChild(this.createProductImage(notification));
        }

        notifDiv.appendChild(this.createContent(notification));
        notifDiv.appendChild(this.createCloseButton(notification.id));
        notifDiv.appendChild(this.createProgressBar());

        if (notification.product_url) {
            notifDiv.addEventListener('click', function(event) {
                self.redirectToProduct(notification, event);
            });

            notifDiv.addEventListener('touchstart', function(event) {
                self.handleTouchStart(event);
            });

            notifDiv.addEventListener('touchend', function(event) {
                self.handleTouchEnd(event, notification);
            });
        }

        notification.element = notifDiv;
        this.container.appendChild(notifDiv);

        setTimeout(function() {
            notifDiv.classList.remove('notification-enter-start');
            notifDiv.classList.add('notification-enter-end', 'notification-visible');
        }, 10);
    };

    LiveActivityNotifications.prototype.createIcon = function(type) {
        var iconDiv = document.createElement('div');
        iconDiv.className = 'live-activity-icon';

        var svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
        svg.setAttribute('class', 'live-activity-icon-svg');
        svg.setAttribute('fill', 'none');
        svg.setAttribute('stroke', 'currentColor');
        svg.setAttribute('viewBox', '0 0 24 24');

        var path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
        path.setAttribute('stroke-linecap', 'round');
        path.setAttribute('stroke-linejoin', 'round');
        path.setAttribute('stroke-width', '2');

        if (type === 'purchase') {
            path.setAttribute('d', 'M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z');
        } else if (type === 'cart_add') {
            path.setAttribute('d', 'M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z');
        } else if (type === 'wishlist_add') {
            svg.setAttribute('fill', 'currentColor');
            svg.removeAttribute('stroke');
            path.setAttribute('d', 'M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z');
            path.removeAttribute('stroke-linecap');
            path.removeAttribute('stroke-linejoin');
            path.removeAttribute('stroke-width');
        } else if (type === 'live_viewers') {
            var path2 = document.createElementNS('http://www.w3.org/2000/svg', 'path');
            path2.setAttribute('stroke-linecap', 'round');
            path2.setAttribute('stroke-linejoin', 'round');
            path2.setAttribute('stroke-width', '2');
            path.setAttribute('d', 'M15 12a3 3 0 11-6 0 3 3 0 016 0z');
            path2.setAttribute('d', 'M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z');
            svg.appendChild(path);
            svg.appendChild(path2);
            iconDiv.appendChild(svg);
            return iconDiv;
        } else if (type === 'trending') {
            path.setAttribute('d', 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6');
        } else if (type === 'low_stock') {
            path.setAttribute('d', 'M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z');
        }

        svg.appendChild(path);
        iconDiv.appendChild(svg);
        return iconDiv;
    };

    LiveActivityNotifications.prototype.createProductImage = function(notification) {
        var imageDiv = document.createElement('div');
        imageDiv.className = 'live-activity-product-image';

        var img = document.createElement('img');
        img.src = notification.product_image;
        img.alt = notification.product_name || '';
        img.loading = 'lazy';

        imageDiv.appendChild(img);
        return imageDiv;
    };

    LiveActivityNotifications.prototype.createContent = function(notification) {
        var contentDiv = document.createElement('div');
        contentDiv.className = 'live-activity-content';

        var messageDiv = document.createElement('div');
        messageDiv.className = 'live-activity-message';

        var messageSpan = document.createElement('span');
        this.populateMessage(messageSpan, notification);
        messageDiv.appendChild(messageSpan);

        contentDiv.appendChild(messageDiv);

        if (notification.product_name) {
            var productDiv = document.createElement('div');
            productDiv.className = 'live-activity-product';

            var productSpan = document.createElement('span');
            productSpan.textContent = notification.product_name;
            productDiv.appendChild(productSpan);

            if (notification.product_url) {
                var linkHint = document.createElement('span');
                linkHint.className = 'live-activity-link-hint';
                linkHint.textContent = ' → ';
                productDiv.appendChild(linkHint);
            }

            contentDiv.appendChild(productDiv);
        }

        return contentDiv;
    };

    LiveActivityNotifications.prototype.populateMessage = function(span, notification) {
        var type = notification.type;

        if (type === 'purchase') {
            var strong = document.createElement('strong');
            strong.textContent = notification.customer_name;
            span.appendChild(strong);
            span.appendChild(document.createTextNode(' from '));
            var locSpan = document.createElement('span');
            locSpan.textContent = notification.customer_location;
            span.appendChild(locSpan);
            span.appendChild(document.createTextNode(' purchased '));
            var timeSpan = document.createElement('span');
            timeSpan.textContent = notification.time_ago;
            span.appendChild(timeSpan);
        } else if (type === 'cart_add') {
            var strong = document.createElement('strong');
            strong.textContent = notification.customer_name;
            span.appendChild(strong);
            span.appendChild(document.createTextNode(' from '));
            var locSpan = document.createElement('span');
            locSpan.textContent = notification.customer_location;
            span.appendChild(locSpan);
            span.appendChild(document.createTextNode(' added to cart '));
            var timeSpan = document.createElement('span');
            timeSpan.textContent = notification.time_ago;
            span.appendChild(timeSpan);
        } else if (type === 'wishlist_add') {
            var strong = document.createElement('strong');
            strong.textContent = notification.customer_name;
            span.appendChild(strong);
            span.appendChild(document.createTextNode(' from '));
            var locSpan = document.createElement('span');
            locSpan.textContent = notification.customer_location;
            span.appendChild(locSpan);
            span.appendChild(document.createTextNode(' added to wishlist '));
            var timeSpan = document.createElement('span');
            timeSpan.textContent = notification.time_ago;
            span.appendChild(timeSpan);
        } else if (type === 'live_viewers') {
            var strong = document.createElement('strong');
            strong.textContent = notification.viewer_count;
            span.appendChild(strong);
            span.appendChild(document.createTextNode(' '));
            var pluralSpan = document.createElement('span');
            pluralSpan.textContent = notification.viewer_count == 1 ? 'person is' : 'people are';
            span.appendChild(pluralSpan);
            span.appendChild(document.createTextNode(' viewing this right now'));
        } else if (type === 'trending') {
            span.appendChild(document.createTextNode('Trending: '));
            var strong = document.createElement('strong');
            strong.textContent = notification.view_count;
            span.appendChild(strong);
            span.appendChild(document.createTextNode(' views in the last '));
            var periodSpan = document.createElement('span');
            periodSpan.textContent = notification.time_period;
            span.appendChild(periodSpan);
        } else if (type === 'low_stock') {
            span.appendChild(document.createTextNode('Stock Alert: Only '));
            var strong = document.createElement('strong');
            strong.textContent = notification.stock_qty;
            span.appendChild(strong);
            span.appendChild(document.createTextNode(' '));
            var pluralSpan = document.createElement('span');
            pluralSpan.textContent = notification.stock_qty == 1 ? 'item' : 'items';
            span.appendChild(pluralSpan);
            span.appendChild(document.createTextNode(' left!'));
        }
    };

    LiveActivityNotifications.prototype.createCloseButton = function(notificationId) {
        var self = this;
        var button = document.createElement('button');
        button.className = 'live-activity-close';
        button.setAttribute('aria-label', 'Close notification');

        var svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
        svg.setAttribute('fill', 'none');
        svg.setAttribute('stroke', 'currentColor');
        svg.setAttribute('viewBox', '0 0 24 24');

        var path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
        path.setAttribute('stroke-linecap', 'round');
        path.setAttribute('stroke-linejoin', 'round');
        path.setAttribute('stroke-width', '2');
        path.setAttribute('d', 'M6 18L18 6M6 6l12 12');

        svg.appendChild(path);
        button.appendChild(svg);

        button.addEventListener('click', function(event) {
            event.stopPropagation();
            self.closeNotification(notificationId);
        });

        return button;
    };

    LiveActivityNotifications.prototype.createProgressBar = function() {
        var progressDiv = document.createElement('div');
        progressDiv.className = 'live-activity-progress';

        var progressBar = document.createElement('div');
        progressBar.className = 'live-activity-progress-bar';
        progressBar.style.animationDuration = this.config.duration + 'ms';

        progressDiv.appendChild(progressBar);
        return progressDiv;
    };

    LiveActivityNotifications.prototype.closeNotification = function(id) {
        var self = this;
        for (var i = 0; i < this.visibleNotifications.length; i++) {
            var notification = this.visibleNotifications[i];
            if (notification.id === id) {
                notification.visible = false;

                if (notification.element) {
                    notification.element.classList.remove('notification-enter-end', 'notification-visible');
                    notification.element.classList.add('notification-leave', 'notification-leave-start');

                    setTimeout(function() {
                        if (notification.element) {
                            notification.element.classList.add('notification-leave-end');
                        }
                    }, 10);

                    setTimeout(function() {
                        if (notification.element && notification.element.parentNode) {
                            notification.element.parentNode.removeChild(notification.element);
                        }
                        self.visibleNotifications = self.visibleNotifications.filter(function(n) {
                            return n.id !== id;
                        });
                    }, 300);
                }
                break;
            }
        }
    };

    LiveActivityNotifications.prototype.handleTouchStart = function(event) {
        this.touchStartTime = Date.now();
        this.touchStartX = event.touches[0].clientX;
        this.touchStartY = event.touches[0].clientY;
    };

    LiveActivityNotifications.prototype.handleTouchEnd = function(event, notification) {
        if (event.target.closest('.live-activity-close')) {
            return;
        }

        if (!notification.product_url) {
            return;
        }

        var touchEndTime = Date.now();
        var touchDuration = touchEndTime - this.touchStartTime;

        var touchEndX = event.changedTouches[0].clientX;
        var touchEndY = event.changedTouches[0].clientY;
        var moveX = Math.abs(touchEndX - this.touchStartX);
        var moveY = Math.abs(touchEndY - this.touchStartY);
        var totalMove = Math.sqrt(moveX * moveX + moveY * moveY);

        if (touchDuration < 500 && totalMove < 10) {
            event.preventDefault();
            setTimeout(function() {
                window.location.href = notification.product_url;
            }, 150);
        }
    };

    LiveActivityNotifications.prototype.redirectToProduct = function(notification, event) {
        if (notification.product_url && !event.target.closest('.live-activity-close')) {
            var isTouchDevice = 'ontouchstart' in window;
            if (!isTouchDevice) {
                window.location.href = notification.product_url;
            }
        }
    };

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', function() {
            var liveActivity = new LiveActivityNotifications();
            liveActivity.init();
        });
    } else {
        var liveActivity = new LiveActivityNotifications();
        liveActivity.init();
    }
})();
</script>
