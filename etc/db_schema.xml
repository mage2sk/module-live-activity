<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="panth_live_activity" resource="default" engine="innodb" comment="Live Activity Events">
        <column xsi:type="int" name="activity_id" unsigned="true" nullable="false" identity="true" comment="Activity ID"/>
        <column xsi:type="varchar" name="activity_type" nullable="false" length="50" comment="Activity Type (purchase, view, cart_add, wishlist)"/>
        <column xsi:type="int" name="product_id" unsigned="true" nullable="true" comment="Product ID"/>
        <column xsi:type="varchar" name="product_name" nullable="true" length="255" comment="Product Name"/>
        <column xsi:type="varchar" name="customer_name" nullable="true" length="255" comment="Customer Name (anonymized)"/>
        <column xsi:type="varchar" name="customer_location" nullable="true" length="100" comment="Customer Location (city/country)"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP" comment="Created At"/>
        <column xsi:type="int" name="store_id" unsigned="true" nullable="false" default="0" comment="Store ID"/>
        <column xsi:type="smallint" name="is_real" unsigned="true" nullable="false" default="1" comment="Is Real Activity (1) or Simulated (0)"/>

        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="activity_id"/>
        </constraint>

        <index referenceId="PANTH_LIVE_ACTIVITY_PRODUCT_ID" indexType="btree">
            <column name="product_id"/>
        </index>

        <index referenceId="PANTH_LIVE_ACTIVITY_CREATED_AT" indexType="btree">
            <column name="created_at"/>
        </index>

        <index referenceId="PANTH_LIVE_ACTIVITY_TYPE" indexType="btree">
            <column name="activity_type"/>
        </index>
    </table>

    <table name="panth_live_activity_stats" resource="default" engine="innodb" comment="Product Activity Statistics">
        <column xsi:type="int" name="stat_id" unsigned="true" nullable="false" identity="true" comment="Stat ID"/>
        <column xsi:type="int" name="product_id" unsigned="true" nullable="false" comment="Product ID"/>
        <column xsi:type="int" name="current_viewers" unsigned="true" nullable="false" default="0" comment="Current Viewers Count"/>
        <column xsi:type="int" name="views_today" unsigned="true" nullable="false" default="0" comment="Views Today"/>
        <column xsi:type="int" name="cart_adds_today" unsigned="true" nullable="false" default="0" comment="Cart Additions Today"/>
        <column xsi:type="int" name="wishlist_adds_today" unsigned="true" nullable="false" default="0" comment="Wishlist Additions Today"/>
        <column xsi:type="int" name="purchases_today" unsigned="true" nullable="false" default="0" comment="Purchases Today"/>
        <column xsi:type="timestamp" name="last_view" nullable="true" comment="Last View Time"/>
        <column xsi:type="timestamp" name="updated_at" nullable="false" default="CURRENT_TIMESTAMP" on_update="true" comment="Updated At"/>

        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="stat_id"/>
        </constraint>

        <constraint xsi:type="unique" referenceId="PANTH_LIVE_ACTIVITY_STATS_PRODUCT_ID">
            <column name="product_id"/>
        </constraint>

        <index referenceId="PANTH_LIVE_ACTIVITY_STATS_CURRENT_VIEWERS" indexType="btree">
            <column name="current_viewers"/>
        </index>
    </table>
</schema>
